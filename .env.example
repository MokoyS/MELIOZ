# Configuration MELIOZ Agency Site
# Copier ce fichier en .env.local et remplir les valeurs

# Authentification admin (ne jamais exposer côté client en production)
VITE_ADMIN_USER=
VITE_ADMIN_PASS=

# Web3Forms (si utilisé)
VITE_WEB3FORMS_KEY=

# Resend API pour l'envoi d'emails (côté serveur uniquement)
RESEND_API_KEY=
